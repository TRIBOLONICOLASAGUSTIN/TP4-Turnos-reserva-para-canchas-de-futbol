# Conexión a PostgreSQL (Neon / Railway / Supabase)
DATABASE_URL="postgresql://user:password@host:5432/ttcsport?sslmode=require"

# Clave secreta para JWT (generá una cadena aleatoria larga)
JWT_SECRET="reemplazar_con_cadena_secreta_larga"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# Puerto del servidor (opcional, default 3001)
PORT=3001
